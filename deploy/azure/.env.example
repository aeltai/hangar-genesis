# Azure and AKS (used by deploy.sh)
# Copy to .env and fill in. Never commit .env or real secrets.

# Your existing AKS cluster
AZURE_SUBSCRIPTION_ID=
AZURE_LOCATION=westeurope
RESOURCE_GROUP_NAME=pse-aeltai-aks-rg25
AKS_CLUSTER_NAME=pse-aeltai-aks25

# Service principal for Azure CLI / kubectl (get-credentials)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# Container registry (required for push and for App Service)
# ACR_NAME=myregistry
# IMAGE_TAG=latest

# Azure App Service (for app-service.sh)
# APP_SERVICE_PLAN_NAME=genesis-plan
# WEBAPP_NAME=pse-genesis-xyz   # must be globally unique *.azurewebsites.net

# Azure Container Apps (for container-app.sh)
# CONTAINERAPP_NAME=genesis-app
# CONTAINERAPP_ENV=genesis-env

# Rancher (for reference; Genesis UI does not require these in the server)
# RANCHER_URL=https://rancher.63.176.138.74.sslip.io
# RANCHER_TOKEN=token-xxx:yyy

# Ingress host for Genesis UI (default: genesis.63.176.138.74.sslip.io)
# GENESIS_INGRESS_HOST=genesis.63.176.138.74.sslip.io
